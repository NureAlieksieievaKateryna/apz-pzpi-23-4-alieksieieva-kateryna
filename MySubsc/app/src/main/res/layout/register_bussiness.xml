<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlexiSubs Business"
            android:textColor="#5B3FFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your business account"
            android:textColor="#6B7280"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Business Registration"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/companyNameInput"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:background="@android:drawable/edit_text"
                android:hint="Business name"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <EditText
                android:id="@+id/businessLoginInput"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@android:drawable/edit_text"
                android:hint="Login"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <EditText
                android:id="@+id/businessDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="14dp"
                android:background="@android:drawable/edit_text"
                android:gravity="top"
                android:hint="Business description"
                android:inputType="textMultiLine"
                android:padding="16dp" />

            <EditText
                android:id="@+id/businessEmailInput"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@android:drawable/edit_text"
                android:hint="Work email"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Spinner
                android:id="@+id/businessTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@android:drawable/edit_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <EditText
                android:id="@+id/businessPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@android:drawable/edit_text"
                android:hint="Password"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Button
                android:id="@+id/businessSignUpButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="#5B3FFF"
                android:text="Create business account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/goToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? Log in"
                android:textColor="#5B3FFF"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_gravity="center" />

        </LinearLayout>

        <TextView
            android:id="@+id/goToClientSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I am a client - register"
            android:textColor="#5B3FFF"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>