<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Plan"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose the best subscription for you"
            android:textSize="16sp"
            android:textColor="#6B7280"
            android:layout_marginTop="6dp" />

        <!-- Starter Plan -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card">

            <TextView
                android:text="Starter Plan"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="$9.99 / month"
                android:textSize="18sp"
                android:textColor="#5B3FFF"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="• 5 Projects&#10;• 20 GB Storage&#10;• Basic Support"
                android:textSize="15sp"
                android:textColor="#4B5563"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/starterPlanButton"
                android:text="Select Plan"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5B3FFF"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"/>
        </LinearLayout>

        <!-- Pro Plan -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card">

            <TextView
                android:text="Pro Plan"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="$24.99 / month"
                android:textSize="18sp"
                android:textColor="#5B3FFF"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="• 20 Projects&#10;• 100 GB Storage&#10;• AI Assistant&#10;• Priority Support"
                android:textSize="15sp"
                android:textColor="#4B5563"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/proPlanButton"
                android:text="Current Plan"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7C3AED"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"/>
        </LinearLayout>

        <!-- Business Plan -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card">

            <TextView
                android:text="Business Plan"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="$49.99 / month"
                android:textSize="18sp"
                android:textColor="#5B3FFF"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="• Unlimited Projects&#10;• 1 TB Storage&#10;• AI Assistant&#10;• Analytics&#10;• Premium Support"
                android:textSize="15sp"
                android:textColor="#4B5563"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/businessPlanButton"
                android:text="Upgrade"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#111827"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>